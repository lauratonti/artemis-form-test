        a                             rhdto:HC22_Digital_Operation ;
        rdfs:label                    "pilot_14 operation_02 Predictive Indoor Climate Forecasting" ;
        rhdto:HP27_concerns_heritage_entity
                artemis:artemis_he_007 ;
        rhdto:HP28_implemented_using  <https://artemis-twin.eu/entity/services/BESS-07> ;
        crm:P134_continued            <https://artemis-twin.eu/entity/pilot_14/operation_01> ;
        crm:P1_is_identified_by       <urn:uuid:81abceb9-d668-4440-bcc3-51595ab15080> , <urn:uuid:0348b961-d4d0-4a1b-a3a0-0107889907c0> ;
        crm:P21_had_general_purpose   <urn:uuid:cb2462a9-918b-4af7-bda1-dd6c47a88b6a> ;
        crm:P2_has_type               <urn:uuid:16393ece-a293-440d-b057-3ae0fa0d2a6b> ;
        crm:P3_has_note               "The Predictive Indoor Climate AI Service (HC15 AI Component) uses the building-specific hygrothermal model — trained on at least one year of real IoT sensor data from the Japanese Tower — to generate 24-hour indoor climate forecasts. The model receives real-time IoT data from operation_01 and external weather forecast data as inputs. Each forecast run is registered in the ARTEMIS KB as a structured record (ForecastID, AssetID, ModelID, ForecastHorizon, InputClimateSource, InputDataURL, ForecastOutputURL, Curator, ForecastTimestamp). Forecast generation time target: <5 minutes. Accuracy targets: within ±1°C for temperature and ±5% RH." ;
        crm:P4_has_time-span          <urn:uuid:2d69a2a6-9471-4b3b-92a2-a342987ad1d8> ;
        crmdig:L10_had_input          <urn:uuid:f3fd9074-2c89-4a3d-a884-74b2fd311d82> , <urn:uuid:cb8a58ca-43e9-48f0-b1c0-f24811817329> ;
        crmdig:L11_had_output         <urn:uuid:dca0bd5f-f7ad-443d-9157-efd2b4559eec> ;
        crmdig:L13_used_parameters    <urn:uuid:6cbc2a77-ecd0-4eec-a227-400d5c2133a5> .

