<https://artemis-twin.eu/entity/pilot_14/operation_03>
        a                             rhdto:HC22_Digital_Operation ;
        rdfs:label                    "pilot_14 operation_03 Historical and Predictive Illumination Simulation" ;
        rhdto:HP27_concerns_heritage_entity
                artemis:artemis_he_007 ;
        rhdto:HP28_implemented_using  <https://artemis-twin.eu/entity/services/BESS-13> ;
        crm:P1_is_identified_by       <urn:uuid:5d41d964-ac13-4156-aabb-0f05e63cfb3d> , <urn:uuid:8d68c0b8-cf48-45a4-91d0-4af5d497e290> ;
        crm:P21_had_general_purpose   <urn:uuid:fbefcfe5-14b1-4731-b060-36bdda286a13> ;
        crm:P2_has_type               <urn:uuid:581e00ad-71de-445d-b2a4-6a8bacb3e1c4> ;
        crm:P3_has_note               "The Illumination Simulation Service computes the cumulative light exposure on accurately mapped material surfaces within the 3D model of the Japanese Tower, using historical outdoor climate data (available back to 1905) and solar path modelling. The simulation produces spatial raster outputs (heatmaps) in GeoTIFF or NetCDF format, visualising where and how much light each surface has received over time. The same engine is used to model future climate scenarios and to simulate the impact of proposed environmental control interventions (e.g. window shading, UV-filtering films) before any physical implementation. The 3D model used as spatial input requires clean watertight mesh geometry. This operation runs independently of the real-time IoT stream (operation_01) but its outputs feed into operation_04 and operation_05." ;
        crm:P4_has_time-span          <urn:uuid:0f4f32fc-3dcc-4bb3-ad6a-3926c15a2a36> ;
        crmdig:L10_had_input          <urn:uuid:64a409f1-92e9-481a-96b2-0bd8bdffe9b0> , <urn:uuid:0e1940e3-462b-4875-a068-f9cbfc0199c0> , <urn:uuid:39a493a8-3f08-42c9-a1f5-52c28df49d91> ;
        crmdig:L11_had_output         <urn:uuid:00384fd3-84ec-4ad5-b148-e45acb98a998> ;
        crmdig:L13_used_parameters    <urn:uuid:489b8aaf-7d29-454d-9ef9-93907b0b5a4a> .

<urn:uuid:0e1940e3-462b-4875-a068-f9cbfc0199c0>
        a                            rhdto:HC24_Digital_Object ;
        rdfs:label                   "The Living Past: A Digital Twin for Environmental Storytelling and Conservation, operation_03, input" ;
