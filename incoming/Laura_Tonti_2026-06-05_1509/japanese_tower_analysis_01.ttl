artemis:analysis170CF402-6D13-4C43-8F9E-0C4C0123350E
        a                              crmhs:HS3_Analysis ;
        rdfs:label                     "Identification of artificial orpiment in the interior decorations of the Japanese Tower in Laeken, Brussels, Belgium" ;
        crmhs:HSP10_used_software      <urn:uuid:d3bddd54-00b9-4d3c-a068-7d3c84fca234> , <urn:uuid:b5d9b865-540f-4bfb-9d15-bacd674dde82> ;
        crmhs:HSP12_used_dataset       <urn:uuid:bb5ecb2f-3335-4b80-a2f4-556c77d9299f> , <urn:uuid:89ec7ba4-30da-4d12-93ef-303311758367> ;
        crmhs:HSP13_used_settings      <urn:uuid:520efea0-d1e5-49a2-b591-c3ab64f5fb89> ;
        crmhs:HSP16_produced_dataset   <urn:uuid:00b13185-a57f-477d-b1a3-4525aeea0383> , <https://doi.org/10.1186/s40494-015-0040-7> ;
        crmhs:HSP1_has_activity_title  <urn:uuid:db24fdd0-9b62-4e37-b434-30475a3bd6dc> ;
        crmhs:HSP2_was_performed_on    artemis:artemis_he_007 ;
        crmhs:HSP4_analysed            <urn:uuid:e91c383a-3b85-48af-8c33-30c66a634f74> , <urn:uuid:0ad22382-1249-41cc-bcb5-f0219674ea73> , <urn:uuid:a1a1dc10-d9fb-47c5-b3e6-41b7e604e3f0> ;
        crmhs:HSP6_used_method         <urn:uuid:89462ac3-97e5-4d7a-a909-e346b18c4fe4> , <urn:uuid:5e79d8bf-5d0b-4006-8da2-331d53f54b12> , <urn:uuid:5e5cf398-c2b3-4115-881e-9b65a284b27d> ;
        crmhs:HSP8_used_device         <urn:uuid:9fb704b5-ba10-4901-8867-53d08f02ea74> , <urn:uuid:18d3437e-f1d4-441f-85ed-d0a667d6c7f5> , <urn:uuid:99d503d6-59db-4764-9627-107f72348ef1> , <urn:uuid:e90f3644-4bc7-438b-96e9-c865916b8397> , <urn:uuid:8da2cadf-6d67-499f-b737-430398a7f122> ;
        crmhs:HSP9_used_component      <urn:uuid:f0925b51-1c73-4a85-9af7-df55ac046f91> , <urn:uuid:d0f2d33e-cb09-4d1f-bff0-b74cd8e992e0> , <urn:uuid:4912f0b1-6cc4-451b-8731-82fbe6e00e18> , <urn:uuid:2919fbb4-3578-4a13-a390-6995ec9d8268> , <urn:uuid:cde443fe-7780-419a-9227-299e04160a6d> ;
        crm:P11_had_participant        <urn:uuid:7e3b9ffd-b152-4fbc-afbf-46a53064f5ab> , <urn:uuid:380ae6ea-c7d8-47cd-9efa-f354653f7b5b> ;
        crm:P14_carried_out_by         <urn:uuid:a5249249-190c-4e3b-9772-cd89bf29bb3f> , <urn:uuid:c30f179d-60a4-4fcf-bc31-720d4da6674c> , <urn:uuid:7027c7da-9a49-4cae-9968-8014351c7adc> ;
        crm:P2_has_type                <urn:uuid:82639961-ea59-4ef4-9d94-6ad3919d33cb> ;
        crm:P3_has_note                "Multi-technique analytical study aimed at identifying the arsenic sulfide pigment used in the decorative panels of the Japanese Tower at the Royal Castle Domain in Laeken, Brussels, Belgium. The study was motivated by the unusually good conservation state of the arsenic sulfide pigment despite its known tendency to fade upon light exposure. The pigment was found applied with different painting techniques: bound with oil and urushi in lacquer layers, and with an aqueous (protein-based) binder in mat relief panels, where it is always applied as an underlayer mixed with ultramarine blue. Among 165 samples taken from the tower for a complete technical study, 24 samples containing arsenic sulfide pigment sampled on different floors were selected. Three representative cross-sections were discussed in detail: C90.058/P210.011, C90.094/P209.066, and C90.101/P209.074. The arsenic sulfide was identified as amorphous arsenic sulfide glass (g-AsxSx), synthesized from arsenic trioxide and sulfur via a dry process. The presence of As4S4 monomer units at different ratios across samples suggests manufacture in different batches and at different quenching temperatures. The unpublished full technical report is archived at KIK-IRPA under number 2010.10826." ;
        crm:P7_took_place_at           <https://www.wikidata.org/wiki/Q816280> .

