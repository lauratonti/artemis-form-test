        a                             rhdto:HC22_Digital_Operation ;
        rdfs:label                    "pilot_04 aoperation_03 Conservation Data Analysis and Dashboard Visualisation" ;
        rhdto:HP27_concerns_heritage_entity
                artemis:artemis_he_006 ;
        rhdto:HP28_implemented_using  <https://artemis-twin.eu/entity/services/artemis_CAW-06> ;
        crm:P134_continued            <https://artemis-twin.eu/entity/pilot_04/operation_02> ;
        crm:P1_is_identified_by       <urn:uuid:89bda1c5-7db6-4b2e-9d49-8e444cec174d> , <urn:uuid:69750834-b469-4a50-b06b-ae19d1003713> ;
        crm:P21_had_general_purpose   <urn:uuid:3a043ae7-7b04-4b1d-9f4c-c53b275ec40d> ;
        crm:P2_has_type               <urn:uuid:5dbe3484-92a8-40fe-90e6-11852a0ba5f5> ;
        crm:P3_has_note               "Real-time and historical data from the Digital Twin are visualised through the ARTEMIS IoT Viewer dashboard. The operation supports multiple user roles: curators and managers access real-time data and alerts; conservators analyse environmental stability and assess potential degradation risks; technical personnel monitor system performance. The operation correlates current sensor readings with past monitoring campaigns to support predictive conservation analytics. It also ingests the output of test scenarios (environmental fluctuation response, degradation suppression, vandalism detection, Digital Twin synchronisation verification)." ;
        crm:P4_has_time-span          <urn:uuid:704688cc-c709-4db9-a1e4-a3bc1cdeb00c> ;
        crmdig:L10_had_input          <urn:uuid:c8a42abf-37e8-4573-be8e-7ae289c3d96d> , <urn:uuid:e301d527-325a-4045-a565-5da13de815c1> , <urn:uuid:7e500a5e-0f69-4899-9eed-fb3703d4fa44> , <urn:uuid:2a75b2b6-3f92-42f2-8df0-8ebe956ae3cd> ;
        crmdig:L11_had_output         <urn:uuid:97fc1dcd-56d1-47ae-b7e6-454537647092> , <urn:uuid:b88cd1ef-e304-4654-bfc1-b2a208d58777> , <urn:uuid:187140d6-44fc-41bf-8426-29a370fd0413> .

<https://artemis-twin.eu/entity/pilots/pilot_04>
        a                        crm:E7_Activity ;
        rdfs:label               "Smart display case for CH protection" ;
        crm:P1_is_identified_by  <urn:uuid:b3ef536f-9c64-46f2-99ae-e7468be6ccf6> , <urn:uuid:40224042-170f-4b80-b684-3076a11b9b40> ;
        crm:P3_has_note          "Pilot 4 focuses on the design, development, and validation of a Smart Display Case for the protection and monitoring of highly sensitive cultural heritage artefacts in museum environments. The pilot is led by SEL and deploys IoT sensors and actuators integrated with the ARTEMIS platform, enabling real-time environmental monitoring, alert generation, and Digital Twin synchronisation for preventive conservation." ;
        crm:P9_consists_of       <https://artemis-twin.eu/entity/pilot_04/aoperation_03> , <https://artemis-twin.eu/entity/pilot_04/operation_02> , <https://artemis-twin.eu/entity/pilot_04/operation_01> .

