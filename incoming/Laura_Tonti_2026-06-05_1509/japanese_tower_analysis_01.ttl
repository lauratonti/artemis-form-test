<urn:uuid:bb5ecb2f-3335-4b80-a2f4-556c77d9299f>
        a                crmhs:HS13_Scientific_Dataset ;
        rdfs:label       "Natural orpiment reference material — Kremer Pigmente GmbH & Co, Aichstetten, Germany" ;
        crm:P3_has_note  "Reference material / reference spectra" .

<urn:uuid:91e4ceaa-9a0d-43fb-98d5-f577cf930f32>
        a                       crmhs:HS10_Sample_Preparation ;
        rdfs:label              "C90.058 (cross-section) / P210.011 (loose, Canada balsam mount)" ;
        crmhs:HSP6_used_method  <urn:uuid:5792d328-e0c7-4ac7-aedf-4657b250884f> ;
        crm:P3_has_note         "The bulk sample was fixed to a 1 cm3 poly(methyl methacrylate) cube using white PVA glue, after which acrylic copolymer resin (Spofacryl, Spofa Dental CZ-10031, Prague) was poured on the sample and a second cube placed on top. The cross-section was left to dry, then polished with water until nearly exposed, and subsequently polished using Micro Mesh polishing cloths in a sequence of grits (2400, 4000, 6000 and 8000 mesh) to a mirror-like surface. The cross-section was gold-coated for SEM-EDX analysis. For PLM, a fraction of the remaining loose sample was dispersed and mounted in Canada balsam (n = 1.55)." .

<urn:uuid:89ec7ba4-30da-4d12-93ef-303311758367>
        a                crmhs:HS13_Scientific_Dataset ;
        rdfs:label       "Laboratory-prepared arsenic sulfide glass (g-AsxSx) — synthesized from arsenic trioxide and sulfur (1:1), Bunsen burner method after Rotter" ;
        crm:P3_has_note  "Reference material / reference spectra" .

<urn:uuid:5e79d8bf-5d0b-4006-8da2-331d53f54b12>
        a                crmhs:HS4_Method ;
        rdfs:label       "Polarized Light Microscopy (PLM)" ;
        crm:P3_has_note  "Investigation of particle shapes, interference colors and optical properties (isotropy/anisotropy) in Canada balsam mounts under slightly polarized and cross-polarized light, to distinguish arsenic sulfide glass from natural orpiment and to infer starting materials." .

