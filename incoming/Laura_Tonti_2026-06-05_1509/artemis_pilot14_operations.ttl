<https://artemis-twin.eu/entity/pilots/pilot_14>
        a                        crm:E7_Activity ;
        rdfs:label               "The Living Past: A Digital Twin for Environmental Storytelling and Conservation" ;
        crm:P1_is_identified_by  <urn:uuid:60640a57-d8a2-471c-bf39-2167147b5200> , <urn:uuid:109b9e4e-2100-4e7e-ad3c-6b27424c9c22> ;
        crm:P3_has_note          "This pilot creates a Heritage Digital Twin of the Japanese Tower in Laeken (Brussels) that reconstructs its historical interior and exterior and simulates the long-term environmental impact of natural light, temperature and humidity on its decorations. When operational, the system continuously acquires IoT sensor data, generates indoor climate forecasts, runs illumination simulations, assesses conservation risks and visualises all data layers on high-fidelity 3D/VR/AR models of the Tower. Pilot leader: KIK-IRPA. Partners: HOF, Pixelated Realities, PHASMATIC, PIN." ;
        crm:P9_consists_of       <https://artemis-twin.eu/entity/pilot_14/operation_02> , <https://artemis-twin.eu/entity/pilot_14/operation_04> , <https://artemis-twin.eu/entity/pilot_14/operation_01> , <https://artemis-twin.eu/entity/pilot_14/operation_03> , <https://artemis-twin.eu/entity/pilot_14/operation_05> .

<urn:uuid:217cbe55-bece-492b-8cb2-1884a43307c2>
        a           crm:E55_Type ;
        rdfs:label  "HC12_Signal" .

<urn:uuid:bef8b990-ffb6-411b-9357-791d7d440176>
        a           crm:E41_Appellation ;
        rdfs:label  "24-hour indoor climate forecast dataset" .

<urn:uuid:c32ba393-f302-4ba4-b7bf-663c5e62dd4e>
        a           crm:E41_Appellation ;
        rdfs:label  "Visualisation and VR/AR performance targets" .

<https://artemis-twin.eu/entity/pilot_14/operation_05>
        a                             rhdto:HC22_Digital_Operation ;
        rdfs:label                    "pilot_14 operation_05 Spatiotemporal Data Visualisation and VR/AR Experience" ;
        rhdto:HP27_concerns_heritage_entity
                artemis:artemis_he_007 ;
        rhdto:HP28_implemented_using  <https://artemis-twin.eu/entity/services/BEDP-03> , <https://artemis-twin.eu/entity/services/BEDP-02> , <https://artemis-twin.eu/entity/services/BEDP-05> , <https://artemis-twin.eu/entity/services/CAW-01> , <https://artemis-twin.eu/entity/services/CAVR-07> ;
        crm:P134_continued            <https://artemis-twin.eu/entity/pilot_14/operation_04> ;
        crm:P1_is_identified_by       <urn:uuid:9bd8646c-3c9a-4021-a62f-a976eab9958e> , <urn:uuid:6ac96a9b-7cd7-46ad-942c-b8e9edec5311> ;
        crm:P21_had_general_purpose   <urn:uuid:5b55eaf3-ccee-44c7-8319-de7972cf089d> ;
        crm:P2_has_type               <urn:uuid:75f10443-da3e-4d60-9141-cb54f977db08> ;
        crm:P3_has_note               "The RHDT visualisation layer fuses all upstream data streams onto the high-fidelity 3D models of the Japanese Tower, enabling users to navigate between the 'as-built' 1905 state and the current 'as-is' state, activate environmental simulation animations (historical sunlight time-lapses, fading visualisation) and query quantitative data on light exposure per surface. Expert users access a feature-rich desktop interface for in-depth analysis, creation of annotations and evidence-based conservation strategy development. The general public accesses a narrative-driven VR/AR experience via museum kiosk, on-site AR on mobile or web-based 3D viewer. Collaborative multi-user VR sessions support at least 2 simultaneous users with simultaneous visualisation and annotation of multiple data layers. The conservation engineer use case supports virtual prototyping of environmental interventions (e.g. shading solutions) by re-running operation_03 with modified parameters and comparing outputs. VR rendering performance target: >=72 FPS on Meta Quest 3. User interaction responsiveness target: <0.5 seconds. Scene loading time target: <10 seconds. API response time target: <2 seconds." ;
        crm:P4_has_time-span          <urn:uuid:89f7263d-14b5-427e-a85c-9b931c2d9cca> ;
        crmdig:L10_had_input          <urn:uuid:55334219-4211-4009-8a90-dae4308daa70> , <urn:uuid:f73f83d7-2da0-4171-b208-d6e8fe8c59f6> , <urn:uuid:bd4bedf9-5bc6-4956-b9de-f02464fdcba1> , <urn:uuid:5e40b106-5e0b-414c-9d28-325a20f7a50f> , <urn:uuid:4883c21e-8032-4ddb-8a44-5c9088e55d4e> ;
        crmdig:L11_had_output         <urn:uuid:f1fadbf1-12c8-4462-8f95-f02ed44a211f> , <urn:uuid:00c7c860-7ced-4e36-80ef-309d13477ebe> ;
        crmdig:L13_used_parameters    <urn:uuid:270efd75-86fa-422a-bff8-8a27ea12a54a> .

