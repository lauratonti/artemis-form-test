        crm:P1_is_identified_by      <urn:uuid:69a4dce4-838e-4ec4-9136-a3f9d4cf2859> , <urn:uuid:d654d217-eaa8-456e-8cf6-102ca9208ad0> ;
        crm:P2_has_type              <urn:uuid:8a01b873-5145-4c96-bbe9-26afc9afa56d> ;
        crm:P3_has_note              "Used for future scenario simulations or virtual prototyping of environmental control interventions (e.g. shading solutions). May be provided as external climate projections or as user-defined HC23 Parameter Set instances." .

