<https://artemis-twin.eu/entity/service/artemis_CAW-06>
        a                             rhdto:HC21_Digital_Service ;
        rdfs:label                    "ARTEMIS IoT Viewer" ;
        rhdto:HP30_provided_by        <urn:uuid:a5fb6ebf-34b9-4e4c-9dc8-d71d32cb6dba> ;
        crm:P102_has_title            <urn:uuid:0d61d5a7-416e-4525-aaf9-0b5e969a2d75> ;
        crm:P103_was_intended_for     <urn:uuid:3d1af04a-8a05-4b99-8bee-45740a2b3f3e> , <urn:uuid:9ff74b4d-cfa9-4b4e-a536-033221f02505> ;
        crm:P125_used_object_of_type  "HC9 Sensor — Environmental sensor" , "HC9 Sensor — Anti-tampering sensor" , "HC25 Node (Wi-Fi-enabled microcontroller unit)" , "HC11 Actuator" ;
        crm:P16i_was_used_for         <urn:uuid:b5786338-7fdd-4813-bbd5-134318fa67e2> , <urn:uuid:a76f6d47-7c70-4812-8f8b-574a8eac8d12> ;
        crm:P2_has_type               <urn:uuid:8b71f560-41d1-44f1-b298-f3258fa892b8> ;
        crm:P3_has_note               "The ARTEMIS IoT Viewer is developed by SEL and is a Web-based application that enables real-time monitoring and control of the Smart Display Case through the Digital Twin. The IoT Viewer allows users to visualise the 3D model of the asset, configure IoT sensors and actuators in the scene, monitor environmental parameters, define automated decision rules and perform manual overrides when necessary. The Viewer communicates with the ARTEMIS IoT Gateway via REST APIs, ensuring continuous synchronisation between the physical case and its digital representation. It provides curators and conservators with a clear and centralised dashboard for real-time data visualisation and historical analysis. The Viewer requires the ARTEMIS IoT Gateway exposing REST microservices and a hybrid data infrastructure composed of the ARTEMIS Triple Store and an IoT Time-Series database. Secure authentication services and WebGL-compatible browsers are necessary to ensure controlled access and 3D visualisation capabilities." ;
        crm:P70i_is_documented_in     <urn:uuid:9cf1983e-1a40-402d-8d77-ee7d0534f0c3> ;
