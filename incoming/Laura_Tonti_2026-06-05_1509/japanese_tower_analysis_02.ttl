<urn:uuid:24e76a6c-e42a-49de-8f0d-6902e01a409c>
        a                crmhs:HS4_Method ;
        rdfs:label       "Pyrolysis Gas Chromatography-Mass Spectrometry (Py-GC-MS)" ;
        crm:P3_has_note  "Used for identification of organic binders including urushi, plant juice, perilla oil, and proteinaceous materials. Samples pyrolyzed at 550°C for 12 sec with TMAH 2.5% in MeOH." .
