<https://artemis-twin.eu/entity/pilot_04/operation_02>
        a                             rhdto:HC22_Digital_Operation ;
        rdfs:label                    "pilot_04 operation_02 Real-Time Digital Twin Synchronisation" ;
        rhdto:HP27_concerns_heritage_entity
                artemis:artemis_he_006 ;
        rhdto:HP28_implemented_using  <https://artemis-twin.eu/entity/services/artemis_BEDP-09> , <https://artemis-twin.eu/entity/services/artemis_CAW-06> ;
        crm:P134_continued            <https://artemis-twin.eu/entity/pilot_04/operation_01> ;
        crm:P1_is_identified_by       <urn:uuid:e3bb2e1b-e63d-4006-a968-603bd5049cea> , <urn:uuid:d6a07fc4-492c-42d5-b7ea-5f9be6cc076d> ;
        crm:P21_had_general_purpose   <urn:uuid:fda656c0-c053-4a30-bde0-e06435a7671c> ;
        crm:P2_has_type               <urn:uuid:1e3d3cc9-79cb-4543-bb91-37a4e68c79d5> ;
        crm:P3_has_note               "Sensor data collected by the IoT monitoring operation are ingested and propagated to the RHDT of the Smart Display Case. The Digital Twin mirrors the physical state of the case in real time, maintaining a maximum synchronisation lag of 10 seconds. The twin stores historical environmental measurements in the IoT Time-Series NoSQL database and links them semantically to the corresponding IoT Nodes and Activities in the ARTEMIS Triple Store. The operation also handles alert generation when environmental or security thresholds are exceeded." ;
