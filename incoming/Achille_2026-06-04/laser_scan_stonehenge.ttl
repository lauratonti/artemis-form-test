#######################################################################################
#
# ARTEMIS Template - Modeling for Stonehenge Scientific Analysis
#
# Part 2: Analysis 1 (Laser Scan, EH Report 32-2012)
#
# This file depends on entities defined in Cultural_Object_Stonehenge.ttl
# (e.g., artemis:Stonehenge, artemis:Place_Stonehenge)
#
#######################################################################################

#################################################################
# DIGITALIZATION PROCESS (Event 1: The 2011 Scan)
#################################################################

artemis:Scan_Stonehenge_2011 a crmdig:D2_Digitization_Process ;
    rdfs:label "Stonehenge 3D Laser Scan (2011)" ;
    crm:P3_has_note "3D laser scan survey commissioned by English Heritage and conducted by Greenhatch Group, creating 0.5mm resolution data." ;
    crmdig:L1_digitized artemis:Stonehenge ; # Linking to the existing Study Object
    crm:P14_carried_out_by artemis:Group_Greenhatch ;
    crm:P4_has_time-span artemis:Timespan_Scan_2011 ;
    crmdig:L12_happened_on_device artemis:Instrument_LaserScanner_Greenhatch ;
    crmdig:L20_has_created artemis:Data_Stonehenge_ScanData_2011 .


#################################################################
# SCIENTIFIC ANALYSIS (Event 2: The 2012 Analysis Report)
#################################################################

artemis:Analysis_StonehengeScan_2012 a crmhs:HS3_Analysis ,
                                        crmdig:D3_Formal_Derivation ;
    rdfs:label "Archaeological Analysis of Stonehenge Scan Data (2012)" ;
    crm:P2_has_type <http://vocab.getty.edu/aat/300054350> ; # archaeological analysis
    crmhs:HSP1_has_activity_title "Stonehenge Laser Scan: Archaeological Analysis Report" ;
    crm:P3_has_note "Archaeological analysis of laser-scan and photogrammetric data to provide new information about stone-working, monument construction, and prehistoric carvings." ;
    crmhs:HSP4_analysed artemis:Stonehenge ; # Linking to the existing Study Object
    crmhs:HSP6_used_method artemis:Method_PTM ,
                           artemis:Method_PlaneShading ,
                           artemis:Method_LuminanceLensing ,
                           artemis:Method_Photogrammetry ;
    crmhs:HSP8_used_instrument artemis:Instrument_Dell_T5500 , # Computer used for analysis
                               artemis:Instrument_Leica_VLUX2 ; # Camera for new photogrammetry
    crmhs:HSP10_used_software artemis:Software_Cinema4D_R13 ,
                              artemis:Software_Pointools ,
                              artemis:Software_Agisoft_PhotoScan ;
    crmhs:HSP13_used_settings artemis:Settings_StonehengeScan_2012 ;
    crmhs:HSP16_produced_dataset ariadne:8917580C-09A2-3E9F-A7C7-6F3E7FF83690 ; # LINK TO ARIADNE
    crm:P14_carried_out_by artemis:Group_ArcHeritage ;
    crm:P11_had_participant artemis:Person_MarcusAbbott , 
                            artemis:Person_HugoAndersonWhymark ,
                            artemis:Person_DaveAspden ,
                            artemis:Person_AnnaBadcock ,
                            artemis:Person_TudurDavies ,
                            artemis:Person_MagsFelter ,
                            artemis:Person_RobIxer ,
                            artemis:Person_MikeParkerPearson ,
                            artemis:Person_ColinRichards ;
    crm:P4_has_time-span artemis:Timespan_Analysis_2012 ;
    crm:P7_took_place_at artemis:Place_ArcHeritage_Sheffield , # Desk analysis
                         artemis:Place_Stonehenge ; # Field visits (links to existing Place)
    crm:P129i_is_subject_of ariadne:8917580C-09A2-3E9F-A7C7-6F3E7FF83690 ; # LINK TO ARIADNE
    # CRMdig properties for the derivation
    crmdig:L21_used_as_derivation_source artemis:Data_Stonehenge_ScanData_2011 ; # INPUT
    crmdig:L22_created_derivative ariadne:8917580C-09A2-3E9F-A7C7-6F3E7FF83690 , # OUTPUT (Report)
                                  artemis:Data_Stonehenge_PTM_2012 .  # OUTPUT (Visualizations)

#################################################################
# SCIENTIFIC METHODS (for Laser Scan Analysis)
#################################################################

artemis:Method_PTM a crmhs:HS4_Method ;
    crm:P2_has_type "Polynomial Texture Mapping (PTM)" ;
    crm:P3_has_note "Creation of PTM files from 0.5mm mesh data by synthesizing 280 images with different light sources to interactively re-light the surface." .

artemis:Method_PlaneShading a crmhs:HS4_Method ;
    crm:P2_has_type "Greyscale 'Plane Shading' Visualization" ;
    crm:P3_has_note "Analysis of point cloud data in Pointools using a 'plane shading' function with a 75mm greyscale band moved at 1mm intervals." .

artemis:Method_LuminanceLensing a crmhs:HS4_Method ;
    crm:P2_has_type "Luminance Lensing" ;
    crm:P3_has_note "A custom in-house technique (ArcHeritage) using a custom shader in Cinema 4D to adjust the luminance channel of a material applied to a 3D mesh." .

artemis:Method_Photogrammetry a crmhs:HS4_Method ;
    crm:P2_has_type "Convergent Photogrammetry" ;
    crm:P3_has_note "Data collection with a Leica V-LUX 2 Camera, processed using Agisoft PhotoScan to create higher-resolution meshes than the scan data." .

#################################################################
# SCIENTIFIC INSTRUMENTS (for Laser Scan Analysis)
#################################################################

artemis:Instrument_LaserScanner_Greenhatch a crmdig:D8_Digital_Device ,
                                            crmhs:HS11_Scientific_Device ;
    rdfs:label "Greenhatch Group Laser Scanner" ;
    crmhs:HSP23_has_model "Unknown" ;
    crmhs:HSP22_has_maker "Greenhatch Group" ;
    crm:P52_has_current_owner artemis:Group_Greenhatch .

artemis:Instrument_Leica_VLUX2 a crmdig:D8_Digital_Device ,
                                crmhs:HS11_Scientific_Device ;
    rdfs:label "Leica V-LUX 2 Camera" ;
    crmhs:HSP23_has_model "V-LUX 2" ;
    crmhs:HSP22_has_maker "Leica" ;
    crm:P52_has_current_owner artemis:Group_ArcHeritage .

artemis:Instrument_Dell_T5500 a crmdig:D8_Digital_Device ,
                                crmhs:HS11_Scientific_Device ;
    rdfs:label "Dell Precision T5500 Workstation" ;
    crmhs:HSP23_has_model "Precision T5500" ;
    crmhs:HSP22_has_maker "Dell" ;
    crm:P52_has_current_owner artemis:Group_ArcHeritage .

#################################################################
# SOFTWARE (for Laser Scan Analysis)
#################################################################

artemis:Software_Cinema4D_R13 a crmhs:D14_Software ;
    crm:P2_has_type "Cinema 4D R13" ;
    crm:P3_has_note "Software used for 3D environment visualization, PTM creation, and Luminance Lensing." .

artemis:Software_Pointools a crmhs:D14_Software ;
    crm:P2_has_type "Pointools" ;
    crm:P3_has_note "Software used for point cloud visualization using the 'plane shading' function." .

artemis:Software_Agisoft_PhotoScan a crmhs:D14_Software ;
    crm:P2_has_type "Agisoft PhotoScan" ;
    crm:P3_has_note "Convergent photogrammetric solution used to process data from the Leica V-LUX 2." .

#################################################################
# ANALYSIS SETTINGS (for Laser Scan Analysis)
#################################################################

artemis:Settings_StonehengeScan_2012 a crmhs:HS14_Analysis_Settings ;
    rdfs:label "Settings for Stonehenge Laser Scan Analysis" ;
    crmhs:HSP14_has_setting_value "Laser Scan Data Resolution (Input): 1mm and 0.5mm mesh" ;
    crmhs:HSP14_has_setting_value "Photogrammetry Data Resolution (Input): > 0.5mm" ;
    crmhs:HSP14_has_setting_value "PTM Generation: 280 lights, hemispheric pattern" ;
    crmhs:HSP14_has_setting_value "Plane Shading: 75mm optimum depth greyscale band" ;
    crmhs:HSP14_has_setting_value "Plane Shading Animation: 75 images, 1mm intervals" ;
    crmhs:HSP15_is_specified_in ariadne:8917580C-09A2-3E9F-A7C7-6F3E7FF83690 . # LINK TO ARIADNE

#################################################################
# DIGITAL OBJECTS (for Laser Scan Analysis)
#################################################################

artemis:Data_Stonehenge_ScanData_2011 a crmdig:D9_Data_Object ;
    rdfs:label "Stonehenge Laser Scan Data (2011)" ;
    crm:P2_has_type <http://vocab.getty.edu/aat/300263625> ; # laser scanning
    crm:P3_has_note "850GB dataset of point clouds, 1mm resolution mesh, and 0.5mm mesh (for four stone surfaces) generated by Greenhatch Group." .

artemis:Data_Stonehenge_PTM_2012 a crmdig:D9_Data_Object ;
    rdfs:label "Stonehenge PTM and Visualization Data (2012)" ;
    crm:P2_has_type aat:300233630 ; # (digital images)
    crm:P3_has_note "Polynomial Texture Mapping (PTM) files, plane shading animations, and luminance lens visualizations created by ArcHeritage." .

