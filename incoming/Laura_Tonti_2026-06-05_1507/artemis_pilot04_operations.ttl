        crm:P16_used_specific_object  <urn:uuid:9315ed6b-1ca3-4406-a436-bf37f0d8b22c> , <urn:uuid:2f2b7892-724f-4e04-b627-3474d0b212dd> , <urn:uuid:4a32d27e-8639-4418-bc16-30cdd33d93d3> , <urn:uuid:1bfa9f12-a57b-49b3-8548-169d217eaf93> , <urn:uuid:f580cd43-3a29-4390-a8eb-b5e38fcd0173> , <urn:uuid:7455a8d2-dcfc-4771-8cb8-9258622730db> ;
