<https://artemis-twin.eu/entity/pilot_14/operation_04>
        a                             rhdto:HC22_Digital_Operation ;
        rdfs:label                    "pilot_14 operation_04 Risk Assessment and Alerting" ;
        rhdto:HP27_concerns_heritage_entity
                artemis:artemis_he_007 ;
        rhdto:HP28_implemented_using  <https://artemis-twin.eu/entity/services/BESS-08> ;
        crm:P134_continued            <https://artemis-twin.eu/entity/pilot_14/operation_02> ;
        crm:P1_is_identified_by       <urn:uuid:4901735b-97c2-4b3f-8e7d-256f70bfa327> , <urn:uuid:6ff7d547-b83a-439b-b896-bc942d041fa5> ;
        crm:P21_had_general_purpose   <urn:uuid:bfcc7269-3892-4198-91b1-1e4f81f46f9b> ;
        crm:P2_has_type               <urn:uuid:c688b09e-572e-4ec0-8d48-c9ec0ef7aa22> ;
        crm:P3_has_note               "The Risk Assessment Service continuously processes three categories of input: (1) real-time IoT measurements from operation_01, (2) 24-hour indoor climate forecasts from operation_02, and (3) illumination simulation heatmaps from operation_03. When any data source indicates that a condition will breach a user-defined threshold (e.g. RH >70%, excessive light dose), the service generates a Risk Event record logged in the ARTEMIS KB (EventID, AssetID, LocationDesc, RiskType, RiskLevel, RiskBasis, RiskMetrics, EventTimestamp, CreationTimestamp, TriggeringSource, NotificationLog) and issues notifications to relevant personnel. Risk assessment latency target: <1 second. KB synchronisation target: within 1 hour of the event." ;
        crm:P4_has_time-span          <urn:uuid:36feae75-a700-4f54-b26a-da80aef4f64f> ;
        crmdig:L10_had_input          <urn:uuid:744eb7ef-6c30-4144-aefd-69b718dc818a> , <urn:uuid:9c419a06-9538-441f-869b-a3488fe24b7e> , <urn:uuid:3d7a3502-9ef5-492e-b859-61828867acba> ;
        crmdig:L11_had_output         <urn:uuid:007f3909-91f0-4f59-b94a-62c7d0546185> , <urn:uuid:f651adce-9c60-43d0-9e5e-a909c70c6f2a> ;
        crmdig:L13_used_parameters    <urn:uuid:f8c78baf-edc0-42fe-aea5-f42ffde50908> .

