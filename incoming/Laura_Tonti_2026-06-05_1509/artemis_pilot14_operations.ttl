        a                             rhdto:HC22_Digital_Operation ;
        rdfs:label                    "pilot_14 operation_01 Real-time IoT Environmental Monitoring" ;
        rhdto:HP27_concerns_heritage_entity
                artemis:artemis_he_007 ;
        rhdto:HP28_implemented_using  <https://artemis-twin.eu/entity/services/BEDP-07> ;
        crm:P16_used_specific_object  <urn:uuid:59a8bbb3-8cd9-4835-acad-21dfc0b39006> , <urn:uuid:171ae251-0f96-4ddf-b077-40bca973c8e7> ;
        crm:P1_is_identified_by       <urn:uuid:9558892a-7e08-4f9d-ac6d-0bf91b2e8268> , <urn:uuid:8d654a44-b3bf-4db5-9dfc-2dc3b063187f> ;
        crm:P21_had_general_purpose   <urn:uuid:d1a03c3f-02c8-4b8f-ba8b-c5201aad45cb> ;
        crm:P2_has_type               <urn:uuid:3674704b-634f-4bc5-936d-37c5667d4df4> ;
        crm:P3_has_note               "The IoCT sensor network continuously monitors indoor parameters (air temperature, surface temperatures, relative humidity, light levels in visual/infrared/ultraviolet, airborne dust particles, CO2 concentrations) and outdoor meteorological parameters (temperature, RH, rainfall, wind direction, wind speed, solar radiation) via an on-site weather station. Data is logged automatically at 10–15 minute intervals, stored locally in .csv or .txt and transmitted to the RHDT platform via MQTT. Each sensor node is registered as a unique asset in the ARTEMIS KB (NodeID, SensorID, LocationDesc, SensorType, DataTypes, DataUnits, DeploymentDate, Status, Interval, DatasetURL). System uptime target: >=90%. Data completeness target: >=95% of expected readings per day. Data transmission latency target: <5 seconds." ;
        crm:P4_has_time-span          <urn:uuid:0017418e-4a75-43e2-80c6-2b9a66e0a324> ;
        crmdig:L10_had_input          <urn:uuid:a2ab8f27-46ab-4c93-8047-0d9b891d6ee5> , <urn:uuid:965763af-9c2f-4e5a-b407-a567db9085a6> ;
