<https://artemis-twin.eu/entity/service/artemis_BEDP-09>
        a                             rhdto:HC21_Digital_Service ;
        rdfs:label                    "IoT Services" ;
        rhdto:HP30_provided_by        <urn:uuid:121d472a-3e99-4886-ad63-35b4af15e8cc> ;
        crm:P102_has_title            <urn:uuid:f3659550-bdf6-41d7-ad3b-1addcb1c6da1> ;
        crm:P103_was_intended_for     <urn:uuid:04cdda45-7663-4c91-9b32-e8e1c72fa411> , <urn:uuid:a212c3fc-f80a-41e3-a7b5-25da6ad64363> ;
        crm:P125_used_object_of_type  "HC9 Sensor — Light sensor" , "HC9 Sensor — Ground movement sensor" , "HC25 Node (IoT node with Arduino Nano 33 IoT microprocessor)" , "HC9 Sensor — Humidity sensor" , "HC9 Sensor — Temperature sensor" ;
        crm:P16i_was_used_for         <urn:uuid:e99e6e72-1a3c-474d-bf7b-9ad3b1b75ede> ;
        crm:P2_has_type               <urn:uuid:4364a659-6a0f-435b-bfbe-1c708f4f0604> ;
        crm:P3_has_note               "The IoT service uses the physical installation of IoT nodes with sensors to collect data. Specifically, the sensors measure temperature, humidity, light, ground movements and microvegetation. IoT nodes are housed in a box measuring 120x80x75 mm, containing an electronic board designed and developed by SEL, which uses an Arduino Nano 33 IoT as the microprocessor. Environmental sensors are produced by third-party manufacturers and purchased by SEL. A solution with a solar panel is designed to ensure power supply to both the nodes and the sensors. The data acquisition and transmission software is developed by SEL and made compliant with the ARTEMIS infrastructure. Sensor data is collected and transmitted to the ARTEMIS cloud-based infrastructure to be stored in a dedicated NoSQL database, using both RESTful services (ARTEMIS IoT Microservices) and the MQTT protocol for efficient, low-latency publish-subscribe communication." ;
        crm:P70i_is_documented_in     <urn:uuid:c2cb2f47-6b88-4991-8d29-2dc00961dab5> ;
        aocat:has_functionality       <urn:uuid:da91e102-5ffe-4971-9d26-363509ab7410> , <urn:uuid:f0727d13-84fc-49dd-a28b-d0c3adfdd604> , <urn:uuid:b6e068d4-d687-47df-968a-8ce3175236ae> , <urn:uuid:4364a659-6a0f-435b-bfbe-1c708f4f0604> , <urn:uuid:43aa1b9e-8102-4a56-87ae-51cf81a0bfd1> ;
        aocat:has_technical_support   <urn:uuid:de00a0d3-97bd-4575-b9c3-0f6c40c53d3c> .

