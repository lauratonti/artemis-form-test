    <used_method>
      <method>
        <method_name>Macro X-ray Fluorescence Scanning (MA-XRF)</method_name>
        <method_notes>MA-XRF is a non-invasive, non-destructive mapping technique that scans the painted surface with a focused X-ray beam and collects the fluorescence signal pixel by pixel, producing elemental distribution maps across the entire surface. It allows identification of pigments and hidden layers based on their elemental composition.</method_notes>
      </method>
    </used_method>
    <used_protocol>
      <protocol>
        <protocol_name>In situ MA-XRF scanning protocol (VAST-Lab)</protocol_name>
        <protocol_notes>The instrument was operated in situ at the Pinacoteca di Brera conservation laboratory. Scan sessions were planned to ensure full surface coverage with overlapping regions. The sample-to-detector distance was maintained constant via a laser distance sensor. Scan parameters were validated against reference standards prior to each session.</protocol_notes>
      </protocol>
    </used_protocol>
