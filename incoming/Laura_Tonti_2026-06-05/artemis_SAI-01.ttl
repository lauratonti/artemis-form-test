<https://artemis-twin.eu/entity/service/artemis_SAI-01>
        a                             rhdto:HC21_Digital_Service ;
        rdfs:label                    "Smart Display Case" ;
        rhdto:HP30_provided_by        <urn:uuid:e517bbc0-de6d-4abf-a784-13de72854872> ;
        crm:P102_has_title            <urn:uuid:9b4c197d-fef7-4b42-9eb7-296253507b19> ;
        crm:P103_was_intended_for     <urn:uuid:4639e8a7-bb49-4ecb-b059-3e4abfcad9a6> , <urn:uuid:6c817bf4-6198-416d-ae3e-a8be6c5110a7> , <urn:uuid:141939e3-7be0-4a86-b280-792ef32d3755> ;
        crm:P125_used_object_of_type  "HC11 Actuator — Controlled access actuator" , "HC9 Sensor — Light sensor" , "HC9 Sensor — Anti-tampering sensor (access detection)" , "HC11 Actuator — Environmental regulation actuator" , "HC9 Sensor — Temperature sensor" , "HC9 Sensor — Humidity sensor" , "HC25 Node (Wi-Fi-enabled microcontroller unit)" ;
        crm:P2_has_type               <urn:uuid:8e9ba217-0ce0-41e2-9b35-5eb13075aa26> ;
        crm:P3_has_note               "The Smart Display Case is a custom-designed protective enclosure developed for the preventive conservation of sensitive cultural heritage artefacts and integrated with the ARTEMIS framework. The display case integrates a remotely controllable glass lifting mechanism, and is equipped with environmental and security sensors, as well as actuators defined within the project, enabling continuous monitoring and automated regulation of internal microclimatic conditions. Through its integration with the ARTEMIS IoCT services, the physical case operates as the tangible component of the RHDT. From a hardware perspective, the Smart Display Case consists of a hydro-resistant MDF and is equipped with 3+3 extra-clear laminated glass panels, an integrated remote lifting mechanism and a set of embedded IoT sensors and actuators. These include environmental sensors (e.g. temperature, humidity, light), anti-tampering sensors (e.g. access detection) and actuators for environmental regulation or controlled access. The system includes Wi-Fi-enabled microcontroller units that manage sensor data acquisition and actuator control, ensuring secure communication with the ARTEMIS infrastructure. The internal exhibition space has the following dimensions: Width 700 mm, Height 500 mm, Depth 500 mm." ;
        crm:P70i_is_documented_in     <urn:uuid:7b03e695-e09f-44dd-995a-8395a68f0fdb> ;
