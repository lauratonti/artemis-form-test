        crmhs:HSP16_produced_dataset   <urn:uuid:d25e2cc6-479e-4eb2-a063-e910fd137a57> , <https://doi.org/10.1080/00393630.2016.1227053> , <urn:uuid:38ae6a1f-a1c1-4114-a3e7-10f1dcb28fc8> ;
        crmhs:HSP1_has_activity_title  <urn:uuid:acfb919e-9113-4901-b60a-0928fa65f37f> ;
        crmhs:HSP2_was_performed_on    artemis:artemis_he_007 ;
        crmhs:HSP4_analysed            <urn:uuid:a54555bb-6550-465a-b026-9ca1272a815b> , <urn:uuid:d4c9683c-9dc6-4f59-b5b3-fb6b4d2497bc> , <urn:uuid:de70cd0d-b120-44ab-9599-9c3d9cbb93f1> , <urn:uuid:f1b9ac51-d912-4bb0-8c45-acc2793ef069> , <urn:uuid:1e465c8d-4b19-44a8-985f-c32e584bb9ad> , <urn:uuid:5c87d139-1fa6-4ffa-ab0e-bfaadb70d419> ;
        crmhs:HSP6_used_method         <urn:uuid:93230734-6fd6-4a60-b9f3-e33b32224e8d> , <urn:uuid:24e76a6c-e42a-49de-8f0d-6902e01a409c> , <urn:uuid:97132143-fc6e-4a24-a81e-b76c1ca09971> , <urn:uuid:b6157c50-3188-407b-95ad-941b34eb60f5> , <urn:uuid:6805b389-e178-4b25-bb1c-df64bde45971> , <urn:uuid:3e35c53b-4144-4c5e-bfec-ec6c6ece6a28> , <urn:uuid:657160e5-a1a2-466c-8a2a-b2fa4f312b35> ;
        crm:P11_had_participant        <urn:uuid:58c1aa33-a0c2-499d-bc4b-3fdc063b570c> , <urn:uuid:c4847350-93c1-4dc8-a043-8046a669d823> , <urn:uuid:c79808ca-3e8f-413a-836e-6e0be490c517> , <urn:uuid:329e3f30-7838-4c44-873a-7ba1565a3290> , <urn:uuid:e5439e5f-7f6d-4117-b312-e5dd28eae97d> , <urn:uuid:d6b51bc2-4681-4245-bc48-f73f4f71563c> ;
        crm:P14_carried_out_by         <urn:uuid:ac5637f4-7ce2-4792-af2b-102d4eed289f> , <urn:uuid:f1c7d716-b698-4e35-947e-23c046d536b0> , <urn:uuid:adce831e-4d88-4453-9eba-31aa1e1ed85b> , <urn:uuid:1004a6f2-6e62-4821-b418-bc59adefabd2> , <urn:uuid:08655aca-ba0f-4d33-b8bb-39b7b3f022c3> , <urn:uuid:ac48d4f5-2271-44ec-9a0d-1d6f13a4d208> , <urn:uuid:12184209-703a-44b9-891f-6deed587150c> , <urn:uuid:d11b6cce-30a4-488b-9b9b-8fd69147ca6d> , <urn:uuid:808edbf6-e537-4894-b475-237a43e1226c> , <urn:uuid:8c06bb61-dca0-4316-a1da-9d3ec675131f> ;
        crm:P2_has_type                <urn:uuid:cdfe1a2e-fdc7-454e-bbfb-155a53c1479b> ;
        crm:P3_has_note                "Multidisciplinary study of the upper floors (1–5) of the Japanese Tower at the Royal Castle Domain in Laeken, Brussels, carried out by Fenikx bvba between September 2010 and November 2013, at the request of the Belgian Buildings Agency. The research combined archival research, in situ architectural and material survey, and scientific analysis. It led to the identification of decorative techniques and materials used in each decorative element, which were mapped for future conservation reference, and to the compilation of a detailed damage record. A significant variety of Japanese lacquer techniques was identified: monochrome lacquer (black, red, green, yellow), nashiji, maki-e, takamaki-e, and the architectural technique ikkei saishiki. Scientific analysis identified urushi lacquer (with additives including plant juice and perilla oil) in the upper coloured layers, and a mixture of proteinaceous binder with urushi in the ground layers. Red lacquer layers were pigmented with mercury sulphide (HgS); green seishitsu urushi on the second floor was pigmented with a mixture of Prussian blue and artificial orpiment (as confirmed by Vermeulen et al. 2015). Nashiji decoration on the third floor revealed tin flakes sprinkled on a layer of red lacquer. International experts (Prof. William Coaldrake, Shigeru Kubodera, Yoshihiko Yamashita) were consulted in 2011–2012. The study also informed the development of a preservation plan for the interior decoration." ;
        crm:P4_has_time-span           <urn:uuid:dfb471af-c9e4-4395-9935-2e069669ceff> ;
        crm:P7_took_place_at           <urn:uuid:9d01cf85-21f7-4803-8613-74fed90f689c> , <https://www.wikidata.org/wiki/Q816280> .

