<https://artemis-twin.eu/entity/service//BEDP-02>
        a                            rhdto:HC21_Digital_Service ;
        rdfs:label                   "Navigational Hypertext Service" ;
        rhdto:HP30_provided_by       <urn:uuid:2f5a03a5-a11a-4026-804b-648b5fbcbff2> ;
        crm:P102_has_title           <urn:uuid:4361a69f-9a4c-4e25-b768-622c08fb7846> ;
        crm:P103_was_intended_for    <urn:uuid:0284c6b9-52a5-4a48-b9c3-24961653ff81> , <urn:uuid:de86dd53-6794-42af-be60-0871c9f39a94> ;
        crm:P16i_was_used_for        <urn:uuid:bf98e178-5060-482d-a3fc-f65d3d8f031f> ;
        crm:P2_has_type              <urn:uuid:365900c7-413f-4ba0-85ed-70b5a302ba7e> ;
        crm:P3_has_note              "A service for the creation and management of links between information entities within the ARTEMIS infrastructure. Unlike traditional binary hyperlinks, the service supports links of arbitrary arity, allowing complex relationships involving multiple entities (e.g. asset A and annotation B are related to metadata C in context D). All links are represented in machine-readable format suitable for integration into knowledge graphs. Links may be directional, supporting semantic navigation between entities. Hosted as a RESTful API on a Docker-compatible web server with a database backend (e.g. PostgreSQL) and optional OAuth2 authentication." ;
        aocat:has_consumed_format    "application/json" ;
        aocat:has_functionality      <urn:uuid:365900c7-413f-4ba0-85ed-70b5a302ba7e> , <urn:uuid:82735032-6537-489e-bf0f-53e9396cf214> , <urn:uuid:4e4ee47b-40ea-405a-a6c6-5395a22ac84f> , <urn:uuid:8f58bdac-55bd-41a2-b3e8-2f0f87d65c26> , <urn:uuid:46e7d0ca-3ec4-42c5-bf1d-4c5dac297a58> , <urn:uuid:06a247b9-898d-4b2c-bf79-f69e3c89f85a> ;
        aocat:has_produced_format    "application/ld+json" , "application/json" ;
